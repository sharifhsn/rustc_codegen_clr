<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RustDotnetVersion Condition="'$(RustDotnetVersion)'==''">10</RustDotnetVersion>
    <TargetFramework>net$(RustDotnetVersion).0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RustProfile Condition="'$(RustProfile)' == ''">release</RustProfile>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="cd_native_job">
      <HintPath>../rustlib/target/x86_64-unknown-dotnet/$(RustProfile)/cd_native_job.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>
