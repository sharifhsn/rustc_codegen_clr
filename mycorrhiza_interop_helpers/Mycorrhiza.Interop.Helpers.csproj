<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AssemblyName>Mycorrhiza.Interop.Helpers</AssemblyName>
    <!-- Must match mycorrhiza::linq::PARAMETER_REBINDER_ASSEMBLY exactly: the Rust interop bridge
         (mycorrhiza/src/linq.rs) resolves this assembly by simple name at runtime (normal
         AssemblyLoadContext probing next to the consuming app's output, no special plumbing).
         Built + copied automatically for any consumer of mycorrhiza by
         `tools/cargo-dotnet/src/interop_helpers.rs` — see its doc comment for the delivery
         mechanism (same "copy a dll next to the build output" pattern `add-nuget` uses, but
         unconditional rather than gated on a per-crate marker directory). -->
  </PropertyGroup>
</Project>
