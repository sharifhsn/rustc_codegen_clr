# Copy this directory to feasibility/validate/projects/<your-project>/ and edit.
# A project descriptor tells the differential runner how to build, run, and compare.

NAME="my_project"

# --- source ---
SRC="local"            # "local": crate is in ./crate/ ; otherwise a git URL to clone
GIT_REV=""             # branch/tag for git sources (optional)
SUBDIR=""              # path to the crate within a git repo (optional)

# --- build / run ---
BIN=""                 # binary name if the crate has several (empty = default)
RUN_ARGS=""            # CLI args, passed identically to both runs
STDIN_FILE=""          # file (relative to this dir) piped to stdin of both runs
BUILD_STD="core,alloc,std,panic_abort"   # crates to build-std for the .NET pass

# --- validation ---
PROFILE="diff"         # "diff": native run is ground truth, diff against .NET run
                       #   (other profiles — expected-file, testsuite — are future work)
# Strip nondeterminism before diffing (a sed -E script). Examples:
#   NORMALIZE='s/0x[0-9a-f]+/0xPTR/g'        # addresses
#   NORMALIZE='/^elapsed:/d'                  # timing lines
NORMALIZE=""

# Tips for picking a good candidate:
#  * deterministic output (no RNG without a fixed seed, no time, no thread races,
#    no HashMap iteration order — use BTreeMap/BTreeSet).
#  * no proc-macro deps (unsupported), keep the dependency tree small to start.
#  * a program that *computes and prints* is ideal — the diff is then meaningful.
#  * a LOCAL crate that lives inside this repo needs an empty `[workspace]` table in its
#    Cargo.toml, or cargo treats it as part of the repo's workspace and refuses to build.
